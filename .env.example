# ─────────────────────────────────────────────────────────────
# PostgreSQL Database
# ─────────────────────────────────────────────────────────────
POSTGRES_USER=his_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=his_db

# ─────────────────────────────────────────────────────────────
# FastAPI Backend
# ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://his_user:change_me_in_production@postgres:5432/his_db
SYNC_DATABASE_URL=postgresql://his_user:change_me_in_production@postgres:5432/his_db
APP_NAME=HIS FHIR API
APP_VERSION=1.0.0
DEBUG=true

# ─────────────────────────────────────────────────────────────
# pgAdmin
# ─────────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@his.local
PGADMIN_PASSWORD=change_me_in_production
